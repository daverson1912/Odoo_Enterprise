<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================
         Vista del wizard: Resumen Fiscal (Ventas + Compras)
    ============================================================ -->
    <record id="view_resumen_ventas_compras_wizard_form" model="ir.ui.view">
        <field name="name">resumen.ventas.compras.wizard.form</field>
        <field name="model">resumen.ventas.compras.wizard</field>
        <field name="arch" type="xml">
            <form string="Resumen Fiscal: Libro de Ventas y Compras">
                <group>
                    <group>
                        <field name="company_id"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                </group>

                <!-- Área de descarga cuando ya fue generado -->
                <group invisible="state == 'draft'">
                    <field name="pdf_file" filename="pdf_filename" widget="binary"/>
                    <field name="pdf_filename" invisible="1"/>
                    <field name="xls_file" filename="xls_filename" widget="binary"/>
                    <field name="xls_filename" invisible="1"/>
                </group>

                <footer>
                    <button name="action_generate_pdf"
                            string="Generar Resumen PDF"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'done'"/>
                    <button name="action_generate_excel"
                            string="Generar Resumen Excel"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'done'"/>
                    <button name="action_generate_pdf"
                            string="Re-generar PDF"
                            type="object"
                            class="btn-secondary"
                            invisible="state == 'draft'"/>
                    <button name="action_generate_excel"
                            string="Re-generar Excel"
                            type="object"
                            class="btn-secondary"
                            invisible="state == 'draft'"/>
                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción ventana -->
    <record id="action_resumen_ventas_compras_wizard" model="ir.actions.act_window">
        <field name="name">Resumen Fiscal (Ventas y Compras)</field>
        <field name="res_model">resumen.ventas.compras.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menú en Contabilidad → Informes -->
    <menuitem id="menu_resumen_ventas_compras"
              name="Resumen Fiscal"
              parent="account.menu_finance_reports"
              action="action_resumen_ventas_compras_wizard"
              sequence="95"/>
</odoo>
